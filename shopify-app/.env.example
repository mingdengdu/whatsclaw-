# ClawApp Environment Configuration
# Copy this to .env and fill in your values

# ── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID      # $29/mo
STRIPE_PRICE_GROWTH=price_YOUR_GROWTH_PRICE_ID        # $79/mo
STRIPE_PRICE_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID # $199/mo

# ── Shopify App ──────────────────────────────
SHOPIFY_API_KEY=YOUR_SHOPIFY_API_KEY
SHOPIFY_API_SECRET=YOUR_SHOPIFY_API_SECRET
SHOPIFY_APP_URL=https://your-clawapp-domain.com
SHOPIFY_SCOPES=read_orders,read_customers,write_customers,read_products

# ── OpenClaw ─────────────────────────────────
OPENCLAW_API_URL=http://localhost:3000
OPENCLAW_API_KEY=YOUR_OPENCLAW_API_KEY

# ── App ──────────────────────────────────────
PORT=4000
APP_SECRET=your_random_secret_for_sessions
DATABASE_URL=sqlite:./clawapp.db

# ── WhatsApp ─────────────────────────────────
# For demo: uses OpenClaw Linked Devices (no Meta API needed)
WHATSAPP_MODE=linked_devices  # or: meta_api
META_PHONE_NUMBER_ID=          # only if using meta_api mode
META_ACCESS_TOKEN=             # only if using meta_api mode
